{
  "kpis": [
    {
      "id": "total_shifts_today",
      "label": "Schichten heute",
      "description": "Gesamtzahl geplanter Schichten für heute"
    },
    {
      "id": "coverage_today",
      "label": "Abdeckung heute",
      "description": "Anteil der Schichten mit zugewiesenem Mitarbeiter",
      "format": "percentage"
    },
    {
      "id": "employees_scheduled_today",
      "label": "Eingesetzte Mitarbeiter heute",
      "description": "Anzahl unterschiedlicher Mitarbeiter mit Schichten heute"
    }
  ],
  "charts": [
    {
      "id": "shifts_per_day",
      "type": "bar",
      "label": "Schichten pro Tag (nächste 7 Tage)",
      "dataset": "shifts_per_day",
      "x": "date",
      "y": "count"
    },
    {
      "id": "shift_type_distribution",
      "type": "pie",
      "label": "Verteilung Schichtarten (nächste 7 Tage)",
      "dataset": "shift_type_distribution",
      "value": "count",
      "name": "shiftType"
    },
    {
      "id": "employee_load",
      "type": "bar",
      "label": "Schichten pro Mitarbeiter (nächste 7 Tage)",
      "dataset": "employee_load",
      "x": "employee",
      "y": "count"
    }
  ],
  "colors": {
    "primary": "#2E86AB",
    "secondary": "#E84855",
    "accent": "#FDBB30",
    "background": "#F4F6F8",
    "text": "#1F1F1F"
  },
  "layout": {
    "desktop": [
      { "component": "kpi", "id": "total_shifts_today", "gridArea": "kpi1" },
      { "component": "kpi", "id": "coverage_today", "gridArea": "kpi2" },
      { "component": "kpi", "id": "employees_scheduled_today", "gridArea": "kpi3" },
      { "component": "chart", "id": "shifts_per_day", "gridArea": "chart1" },
      { "component": "chart", "id": "shift_type_distribution", "gridArea": "chart2" },
      { "component": "chart", "id": "employee_load", "gridArea": "chart3" }
    ],
    "mobile": [
      { "component": "kpi", "id": "total_shifts_today" },
      { "component": "kpi", "id": "coverage_today" },
      { "component": "kpi", "id": "employees_scheduled_today" },
      { "component": "chart", "id": "shifts_per_day" },
      { "component": "chart", "id": "shift_type_distribution" },
      { "component": "chart", "id": "employee_load" }
    ]
  }
}

